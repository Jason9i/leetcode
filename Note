string to integer:
    s.strip() // remove leading and trailing spaces
    if s[0] in '-+':
        s = s.replace(s[0], '', 1) // remove the sign character or s = s[1:]

    while i < len(s) and s[i].isdigit():    
        ans = ans * 10 + int(s[i])
        i += 1

